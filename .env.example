# ─── Discord ──────────────────────────────────────────────────────────────────
# Create an application + bot at https://discord.com/developers/applications
#
# ⚠️  If you previously committed a bot token by accident, ROTATE IT NOW
#     from the Developer Portal → Bot → Reset Token. The old token is burned.
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_id_here

# Optional: register slash commands to a single guild for instant updates
# during development. Leave empty to register globally (up to 1h propagation).
DISCORD_GUILD_ID=

# ─── MySQL ────────────────────────────────────────────────────────────────────
# When running with docker-compose the bot reaches the db service on host "db".
# When running the bot outside Docker, set MYSQL_HOST=localhost (or your host).
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_DATABASE=gwbot
MYSQL_USER=gwbot
MYSQL_PASSWORD=change_me_strong_password
MYSQL_ROOT_PASSWORD=change_me_strong_root_password

# ─── Rendering ────────────────────────────────────────────────────────────────
# Build image style. Options:
#   wiki     (default) — large icons with skill names underneath, attribute pills
#   classic           — original style with progress bars per attribute
BUILD_STYLE=wiki
